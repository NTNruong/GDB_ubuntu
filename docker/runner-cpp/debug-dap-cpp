#!/usr/bin/env bash
set -euo pipefail

cd /workspace
mkdir -p /workspace/tmp
export TMPDIR=/workspace/tmp

echo "__RUNNER_PHASE__:compile:start" >&2
g++ -std=gnu++20 -g -O0 -Wall -Wextra /workspace/main.cpp -o /workspace/program
echo "__RUNNER_PHASE__:compile:done" >&2

gdbserver --once 127.0.0.1:2345 /workspace/program "$@" < /workspace/stdin.txt 1>&2 2>&2 &
target_pid=$!
sleep 0.5

cleanup() {
  kill "$target_pid" 2>/dev/null || true
}
trap cleanup EXIT

exec gdb --interpreter=dap --quiet
