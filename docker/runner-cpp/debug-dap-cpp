#!/usr/bin/env bash
set -euo pipefail

cd /workspace
mkdir -p /workspace/tmp
export TMPDIR=/workspace/tmp

echo "__RUNNER_PHASE__:compile:start" >&2
shopt -s nullglob
cpp_sources=(/workspace/*.cpp /workspace/*.cc)
shopt -u nullglob
if [ ${#cpp_sources[@]} -eq 0 ]; then
  echo "No C++ source file to compile" >&2
  exit 1
fi
g++ -std=gnu++20 -g -O0 -Wall -Wextra "${cpp_sources[@]}" -o /exec/program
echo "__RUNNER_PHASE__:compile:done" >&2

cat > /tmp/gdb-stdin.gdb << 'GDBEOF'
set exec-wrapper sh -c 'exec stdbuf -o0 -e0 "$@" </workspace/stdin.txt >/workspace/tmp/program.out 2>&1' --
GDBEOF
exec gdb --interpreter=dap --quiet --init-command=/tmp/gdb-stdin.gdb
