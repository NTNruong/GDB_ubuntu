#!/usr/bin/env bash
set -euo pipefail

cd /workspace
mkdir -p /workspace/tmp
export TMPDIR=/workspace/tmp

echo "__RUNNER_PHASE__:compile:start" >&2
shopt -s nullglob
c_sources=(/workspace/*.c)
shopt -u nullglob
if [ ${#c_sources[@]} -eq 0 ]; then
  echo "No C source file to compile" >&2
  exit 1
fi
gcc -std=gnu17 -O2 -pipe -Wall -Wextra "${c_sources[@]}" -o /exec/program -lm
echo "__RUNNER_PHASE__:compile:done" >&2

echo "__RUNNER_PHASE__:run:start" >&2
# Report CPU time (user+sys), not wall-clock: it is independent of scheduler
# jitter / cgroup CPU throttling, so the number is reproducible. Compiled
# languages have no runtime warmup to exclude, so the whole-process CPU time
# (%U+%S from /usr/bin/time) is reported with scope=process.
run_with_metrics() {
  local rss_file="/workspace/tmp/run-rss.txt"
  local cpu_file="/workspace/tmp/run-cpu.txt"
  rm -f "$rss_file" "$cpu_file"

  set +e
  /usr/bin/time -f "max_rss_kb=%M user_s=%U sys_s=%S" -o "$rss_file" \
    /usr/bin/timeout --signal=KILL "${RUN_TIMEOUT_SECONDS:-30}s" "$@" < /workspace/stdin.txt
  local exit_code=$?
  set -e

  local max_rss_kb cpu_seconds scope
  max_rss_kb="$(sed -n 's/.*max_rss_kb=\([0-9]*\).*/\1/p' "$rss_file" 2>/dev/null | tail -n 1)"

  # Prefer the in-process user-code CPU time (Java/Python/JS write run-cpu.txt);
  # else fall back to the whole-process CPU time (%U+%S) from /usr/bin/time.
  if [[ -s "$cpu_file" ]]; then
    cpu_seconds="$(tail -n 1 "$cpu_file")"
    scope="user-code"
  else
    local user_s sys_s
    user_s="$(sed -n 's/.*user_s=\([0-9.]*\).*/\1/p' "$rss_file" 2>/dev/null | tail -n 1)"
    sys_s="$(sed -n 's/.*sys_s=\([0-9.]*\).*/\1/p' "$rss_file" 2>/dev/null | tail -n 1)"
    cpu_seconds="$(awk -v u="${user_s:-0}" -v s="${sys_s:-0}" 'BEGIN { printf "%.6f", u + s }')"
    scope="process"
  fi

  if [[ -n "$max_rss_kb" && -n "$cpu_seconds" ]]; then
    printf "__RUNNER_METRIC__:run:cpu_seconds=%s:max_rss_kb=%s:scope=%s\n" \
      "$cpu_seconds" "$max_rss_kb" "$scope" >&2
  fi

  return "$exit_code"
}

run_with_metrics /exec/program "$@"
