#!/usr/bin/env bash
set -euo pipefail

cd /workspace
mkdir -p /workspace/tmp /workspace/classes
export TMPDIR=/workspace/tmp

# Pick the JDK requested via JAVA_VERSION (set by the runner from the request's
# toolchainVersion). Fall back to 21 if unset or the version dir is missing.
java_version="${JAVA_VERSION:-21}"
if [ ! -d "/opt/java/${java_version}" ]; then
  java_version="21"
fi
export JAVA_HOME="/opt/java/${java_version}"
export PATH="${JAVA_HOME}/bin:${PATH}"

echo "__RUNNER_PHASE__:compile:start" >&2
shopt -s nullglob
java_sources=(/workspace/*.java)
shopt -u nullglob
if [ ${#java_sources[@]} -eq 0 ]; then
  echo "No Java source file to compile" >&2
  exit 1
fi
javac -d /workspace/classes "${java_sources[@]}"
echo "__RUNNER_PHASE__:compile:done" >&2

echo "__RUNNER_PHASE__:run:start" >&2
# Report CPU time (user+sys), not wall-clock. The _RunnerMain launcher (compiled
# into /opt/runner at image build) measures process CPU around the user's
# Main.main(), writing run-cpu.txt, so the reported CPU excludes JVM startup
# (scope=user-code).
run_with_metrics() {
  local rss_file="/workspace/tmp/run-rss.txt"
  local cpu_file="/workspace/tmp/run-cpu.txt"
  rm -f "$rss_file" "$cpu_file"

  set +e
  /usr/bin/time -f "max_rss_kb=%M user_s=%U sys_s=%S" -o "$rss_file" \
    /usr/bin/timeout --signal=KILL "${RUN_TIMEOUT_SECONDS:-30}s" "$@" < /workspace/stdin.txt
  local exit_code=$?
  set -e

  local max_rss_kb cpu_seconds scope
  max_rss_kb="$(sed -n 's/.*max_rss_kb=\([0-9]*\).*/\1/p' "$rss_file" 2>/dev/null | tail -n 1)"

  # Prefer the in-process user-code CPU time; else fall back to %U+%S.
  if [[ -s "$cpu_file" ]]; then
    cpu_seconds="$(tail -n 1 "$cpu_file")"
    scope="user-code"
  else
    local user_s sys_s
    user_s="$(sed -n 's/.*user_s=\([0-9.]*\).*/\1/p' "$rss_file" 2>/dev/null | tail -n 1)"
    sys_s="$(sed -n 's/.*sys_s=\([0-9.]*\).*/\1/p' "$rss_file" 2>/dev/null | tail -n 1)"
    cpu_seconds="$(awk -v u="${user_s:-0}" -v s="${sys_s:-0}" 'BEGIN { printf "%.6f", u + s }')"
    scope="process"
  fi

  if [[ -n "$max_rss_kb" && -n "$cpu_seconds" ]]; then
    printf "__RUNNER_METRIC__:run:cpu_seconds=%s:max_rss_kb=%s:scope=%s\n" \
      "$cpu_seconds" "$max_rss_kb" "$scope" >&2
  fi

  return "$exit_code"
}

# Entry class is _RunnerMain (on /opt/runner, ahead of the user's classes); it
# invokes the user's Main. The JVM is cgroup-aware, so the container memory limit
# caps the heap; -XX:-UsePerfData avoids hsperfdata writes under the read-only
# root filesystem.
run_with_metrics java -XX:-UsePerfData -cp /opt/runner:/workspace/classes _RunnerMain "$@"
