#!/usr/bin/env bash
set -euo pipefail

cd /workspace
mkdir -p /workspace/tmp
export TMPDIR=/workspace/tmp

# Same cache setup as run-go (caches on the writable /workspace bind, seeded from the
# image's pre-warmed cache) so the debug build stays inside the compile budget.
export HOME=/workspace/tmp
export GOPATH=/workspace/tmp/go
export GOCACHE=/workspace/tmp/go-build
export GOFLAGS=-mod=mod
mkdir -p "$GOCACHE" "$GOPATH"
cp -a /opt/gocache/. "$GOCACHE/" 2>/dev/null || true

echo "__RUNNER_PHASE__:compile:start" >&2
shopt -s nullglob
go_sources=(/workspace/*.go)
shopt -u nullglob
if [ ${#go_sources[@]} -eq 0 ]; then
  echo "No Go source file to compile" >&2
  exit 1
fi
# Users can't upload go.mod (.mod isn't an allowed extension) — synthesize a module.
[ -f go.mod ] || go mod init runnerapp >/dev/null 2>&1
# -N -l (main package only) disables optimization/inlining for faithful stepping;
# std stays optimized so the pre-warmed cache still hits.
go build -gcflags="-N -l" -o /exec/program .
echo "__RUNNER_PHASE__:compile:done" >&2

# Delve DAP only listens on TCP, but the debug container has no external network
# (loopback only) and the runner attaches over stdio. Start dlv on loopback, then bridge
# the container's stdio to it with socat. dlv's own logs go to a file so they never
# corrupt the DAP byte stream on stdout.
#
# Do NOT pre-probe the port with /dev/tcp: `dlv dap` is single-client, so a probe that
# opens+closes a connection is consumed as THE client and makes Delve tear the server
# down — after which socat gets `Connection refused` (or connects to a dying socket and
# exits 0 with no DAP traffic). Instead let socat itself retry the connect until Delve
# binds, so socat is the one and only DAP client. (ISSUE-058)
PORT=4711
dlv dap --listen=127.0.0.1:${PORT} --log --log-output=dap >/workspace/tmp/dlv.log 2>&1 &
exec socat - TCP:127.0.0.1:${PORT},retry=50,interval=0.1
