#!/usr/bin/env bash
set -euo pipefail

cd /workspace
mkdir -p /workspace/tmp
export TMPDIR=/workspace/tmp

echo "__RUNNER_PHASE__:run:start" >&2
run_with_metrics() {
  local rss_file="/workspace/tmp/run-rss.txt"
  rm -f "$rss_file"

  local start_ns
  start_ns=$(date +%s%N)

  set +e
  /usr/bin/time -f "max_rss_kb=%M" -o "$rss_file" \
    /usr/bin/timeout --signal=KILL "${RUN_TIMEOUT_SECONDS:-30}s" "$@" < /workspace/stdin.txt
  local exit_code=$?
  set -e

  local end_ns elapsed_ms max_rss_kb
  end_ns=$(date +%s%N)
  elapsed_ms=$(( (end_ns - start_ns) / 1000000 ))
  max_rss_kb="$(sed -n 's/^max_rss_kb=//p' "$rss_file" 2>/dev/null | tail -n 1)"

  if [[ -n "$max_rss_kb" ]]; then
    printf "__RUNNER_METRIC__:run:elapsed_seconds=%s:max_rss_kb=%s\n" \
      "$(printf "%d.%03d" $((elapsed_ms / 1000)) $((elapsed_ms % 1000)))" "$max_rss_kb" >&2
  fi

  return "$exit_code"
}

# Keep -I (isolated: no user site, ignore env) for sandbox hardening, but restore
# /workspace on sys.path so a folder run's main.py can import sibling modules
# (-I/-P otherwise strip the script dir from sys.path) — ISSUE-051.
PYRUN='import sys, runpy; sys.path.insert(0, "/workspace"); t = "/workspace/main.py"; sys.argv = [t, *sys.argv[1:]]; runpy.run_path(t, run_name="__main__")'
run_with_metrics python3 -I -c "$PYRUN" "$@"
