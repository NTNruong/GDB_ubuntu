#!/usr/bin/env bash
set -euo pipefail

cd /workspace
mkdir -p /workspace/tmp
export TMPDIR=/workspace/tmp

echo "__RUNNER_PHASE__:run:start" >&2
# Report CPU time (user+sys), not wall-clock. For Python the time is measured
# in-process around the user code (see PYRUN below) and written to run-cpu.txt,
# so interpreter startup is excluded (scope=user-code).
run_with_metrics() {
  local rss_file="/workspace/tmp/run-rss.txt"
  local cpu_file="/workspace/tmp/run-cpu.txt"
  rm -f "$rss_file" "$cpu_file"

  set +e
  /usr/bin/time -f "max_rss_kb=%M user_s=%U sys_s=%S" -o "$rss_file" \
    /usr/bin/timeout --signal=KILL "${RUN_TIMEOUT_SECONDS:-30}s" "$@" < /workspace/stdin.txt
  local exit_code=$?
  set -e

  local max_rss_kb cpu_seconds scope
  max_rss_kb="$(sed -n 's/.*max_rss_kb=\([0-9]*\).*/\1/p' "$rss_file" 2>/dev/null | tail -n 1)"

  # Prefer the in-process user-code CPU time; else fall back to %U+%S.
  if [[ -s "$cpu_file" ]]; then
    cpu_seconds="$(tail -n 1 "$cpu_file")"
    scope="user-code"
  else
    local user_s sys_s
    user_s="$(sed -n 's/.*user_s=\([0-9.]*\).*/\1/p' "$rss_file" 2>/dev/null | tail -n 1)"
    sys_s="$(sed -n 's/.*sys_s=\([0-9.]*\).*/\1/p' "$rss_file" 2>/dev/null | tail -n 1)"
    cpu_seconds="$(awk -v u="${user_s:-0}" -v s="${sys_s:-0}" 'BEGIN { printf "%.6f", u + s }')"
    scope="process"
  fi

  if [[ -n "$max_rss_kb" && -n "$cpu_seconds" ]]; then
    printf "__RUNNER_METRIC__:run:cpu_seconds=%s:max_rss_kb=%s:scope=%s\n" \
      "$cpu_seconds" "$max_rss_kb" "$scope" >&2
  fi

  return "$exit_code"
}

# Keep -I (isolated: no user site, ignore env) for sandbox hardening, but restore
# /workspace on sys.path so a folder run's main.py can import sibling modules
# (-I/-P otherwise strip the script dir from sys.path) — ISSUE-051.
# process_time() is captured just before running the user code and emitted via
# atexit (survives sys.exit()), so the reported CPU excludes interpreter startup.
PYRUN='
import sys, runpy, time, atexit
sys.path.insert(0, "/workspace")
t = "/workspace/main.py"
sys.argv = [t, *sys.argv[1:]]
_cpu0 = time.process_time()
def _emit_cpu():
    try:
        with open("/workspace/tmp/run-cpu.txt", "w") as _f:
            _f.write("%.6f" % (time.process_time() - _cpu0))
    except Exception:
        pass
atexit.register(_emit_cpu)
runpy.run_path(t, run_name="__main__")
'
run_with_metrics python3 -I -c "$PYRUN" "$@"
