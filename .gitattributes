*.sh text eol=lf
# Runner image entrypoints are extensionless bash scripts — force LF so a Windows
# checkout (core.autocrlf=true) never ships CRLF that breaks the in-container shebang.
docker/runner-*/run-* text eol=lf
docker/runner-*/debug-* text eol=lf

# Files excluded from `git archive` (GitHub release ZIP / tarball).
# Source repo keeps them for development; production archive stays minimal.
CLAUDE.md            export-ignore
.gitignore           export-ignore
.gitattributes       export-ignore
.editorconfig        export-ignore
.github/             export-ignore
.vscode/             export-ignore

# Test sources, configs, and fixtures
tests/               export-ignore
**/*.test.ts         export-ignore
**/*.spec.ts         export-ignore
**/*.integration.test.ts export-ignore
playwright.config.ts export-ignore
vitest.config.ts     export-ignore
